{
  "name": "vinext-notion",
  "version": "0.1.0",
  "private": true,
  "description": "Article-only template built on vinext, Notion CMS, and Cloudflare Workers.",
  "scripts": {
    "dev": "vinext dev --port 3001",
    "build": "vinext build",
    "start": "vinext start",
    "deploy:worker": "vinext deploy",
    "migrate:remote": "wrangler d1 migrations apply vinext-notion --remote",
    "deploy:remote": "npm run migrate:remote && npm run deploy:worker",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@notionhq/client": "^5.22.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.40.0",
    "@cloudflare/workers-types": "^4.20260605.1",
    "@tailwindcss/oxide-darwin-arm64": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitejs/plugin-rsc": "^0.5.27",
    "lightningcss-darwin-arm64": "^1.32.0",
    "lightningcss-wasm": "^1.32.0",
    "react-server-dom-webpack": "^19.2.7",
    "tailwindcss": "^4.3.0",
    "typescript": "^5",
    "vinext": "^0.0.55",
    "vite": "^8.0.16",
    "wrangler": "^4.98.0"
  },
  "type": "module"
}
