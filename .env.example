# ===== Notion 集成 =====
# 创建一个 Notion internal integration，把 token 贴到这里
# https://www.notion.so/my-integrations
NOTION_TOKEN=

# 文章 data source ID（必须）
# 现代 Notion API 走 dataSources.query，所以用 data source id，不是 database id
NOTION_DATA_SOURCE_ID=

# 文章翻译 data source ID（可选）
# 不填则只支持默认语言
# NOTION_POSTS_TRANSLATIONS_DATA_SOURCE_ID=

# 可选：Notion 编辑跳转 URL（管理面板跳转用）
# 支持 {pageId} 占位符
# NOTION_EDIT_BASE_URL=https://www.notion.so/{pageId}

# 可选：自定义 Notion API base URL（测试或代理用）
# NOTION_API_BASE_URL=

# ===== 站点 =====
# 公网域名，用于 SEO 与 sitemap
NEXT_PUBLIC_SITE_URL=https://vinext-notion.workers.dev
